# ============================================
# Resume AI Platform — Environment Variables
# Copy this to .env and fill in your API keys
# All APIs have FREE tiers — no payment needed
# ============================================

# ── Resume Folder Path ──
RESUME_DIR=resumes

# ── Database Path ──
DB_PATH=resumes.db

# ── Free AI API Keys (all optional, more = better accuracy) ──

# Cerebras AI — https://cloud.cerebras.ai/ (Free tier)
CEREBRAS_API_KEY=

# Together AI — https://api.together.ai/ (Free $25 credit)
TOGETHER_API_KEY=

# Groq — https://console.groq.com/ (Free tier, ultra-fast)
GROQ_API_KEY=

# Google Gemini — https://aistudio.google.com/apikey (Free 1500 req/day)
GEMINI_API_KEY=

# HuggingFace — https://huggingface.co/settings/tokens (Free, optional)
HF_TOKEN=
